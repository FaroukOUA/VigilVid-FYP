# Server
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000

# Hugging Face Space
HUGGING_FACE_SPACE_ID=farouk04/test_scanly
HUGGING_FACE_GRADIO_API_NAME=/predict

# auto uses Hugging Face when HUGGING_FACE_TOKEN is set, otherwise mock.
# Use mock to avoid spending ZeroGPU quota during UI testing.
DETECTION_BACKEND_MODE=auto

# Server-only secrets. Do not expose these in the Expo app.
# HUGGING_FACE_TOKEN is used for authenticated Space/ZeroGPU/Hugging Face Pro access when required.
HUGGING_FACE_TOKEN=
HUGGING_FACE_DATASET_TOKEN=

# Optional future research dataset upload/indexing.
# Server-only. Keep disabled until explicit raw-video research upload is wired.
HUGGING_FACE_RESEARCH_DATASET_ID=
RESEARCH_DATASET_ENABLED=false

# Public game dataset clip loading.
# Game videos are proxied through the backend. Transcoding keeps odd source
# encodings playable on phones.
HUGGING_FACE_GAME_DATASET_ID=farouk04/vigilvid-research
GAME_CLIP_LOCAL_EXPORT_ROOT=../vigilvid_jepa21_test_export
GAME_CLIP_TRANSCODE_MODE=always
GAME_CLIP_FFMPEG_PATH=
GAME_CLIP_FFPROBE_PATH=
GAME_CLIP_MAX_BYTES=209715200

# Optional backend URL preview/downloader support.
# SAVER_API_KEY is server-only and is used when direct video download is not possible.
SAVER_API_KEY=
SAVER_API_YOUTUBE_QUALITY=720
VIDEO_PREVIEW_MAX_DOWNLOAD_MB=250

# Optional Supabase persistence. These are backend-only values.
SUPABASE_URL=
SUPABASE_PERSISTENCE_ENABLED=false
SUPABASE_SERVICE_ROLE_KEY=
