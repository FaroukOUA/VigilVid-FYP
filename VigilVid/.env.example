# Public Expo client configuration only.
# Expo inlines EXPO_PUBLIC_* values into the app bundle, so do not put secrets here.

# Required for video checking. APK builds must use a reachable backend URL.
EXPO_PUBLIC_API_BASE_URL=https://your-backend.example.com

# Local web/iOS simulator development:
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Local Android emulator development:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

# Physical Android device development on the same Wi-Fi:
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_COMPUTER_LAN_IP:8000

# Optional Supabase Auth client values. Public anon key only.
# Never put Supabase service-role keys or backend secrets in Expo env files.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
